+def test_is_extraction_validated_success(tmp_path):
+    from nagdiff.extraction import is_extraction_validated
+    payload = {
+        "extracted_count": 3,
+        "records": [
+            {
+                "state": "skyrmion_antiskyrmion_merge_to_hopfion",
+                "source_file": "f",
+                "sheet_name": "s",
+                "row": 1,
+                "column": 1,
+                "unit": "pJ",
+                "extraction_method": "f",
+                "notes": "n"
+            },
+            {
+                "state": "hopfion_collapse",
+                "source_file": "f",
+                "sheet_name": "s",
+                "row": 1,
+                "column": 1,
+                "unit": "pJ",
+                "extraction_method": "f",
+                "notes": "n"
+            },
+            {
+                "state": "hopfion_escape",
+                "source_file": "f",
+                "sheet_name": "s",
+                "row": 1,
+                "column": 1,
+                "unit": "pJ",
+                "extraction_method": "f",
+                "notes": "n"
+            }
+        ],
+        "checksums": {"f": "c"}
+    }
+    assert is_extraction_validated(payload) is True
